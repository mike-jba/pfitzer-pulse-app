# ─────────────────────────────────────────────
# Pfitzer Pulse — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────

# ── Supabase (PUBLIC — safe for client-side) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase (SERVER-SIDE ONLY — never expose to browser) ──
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Shared secret for n8n → Next.js API endpoints ──
# n8n must include this in the Authorization header: Bearer <value>
INGEST_SECRET=your-strong-random-secret

# ── AI providers (SERVER-SIDE ONLY) ──
ANTHROPIC_API_KEY=your-anthropic-key
DEEPGRAM_API_KEY=your-deepgram-key

# ── Voice for Pest portal (used by n8n on VPS, not by this app) ──
# Listed here for documentation purposes only.
# ATS_PORTAL_USERNAME=299@pfitzerpestcontrol
# ATS_PORTAL_PASSWORD=your-portal-password
